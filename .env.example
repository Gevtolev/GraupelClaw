# GraupelClaw configuration
#
# Copy this file to .env and adjust values for your local environment.

# Storage backend: "indexeddb" for browser-local storage, or "drizzle" for SQLite.
DB_BACKEND=indexeddb

# SQLite location when DB_BACKEND=drizzle.
PRIVATE_OPENCLAW_CONSOLE_DATA_DIR=./data

# Backward-compatible fallback if you still rely on the old variable name.
CHATCLAW_DATA_DIR=./data

# Enable sign-in only if you want a shared or remotely hosted deployment.
AUTH_ENABLED=false

# Required when AUTH_ENABLED=true.
AUTH_SECRET=

# Enable multiple company/gateway definitions.
MULTI_COMPANY=true
